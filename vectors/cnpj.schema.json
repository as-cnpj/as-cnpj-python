{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cnpj-vectors-v2",
  "title": "Vetores de teste CNPJ do ecossistema AS-CNPJ",
  "type": "object",
  "required": ["metadata", "valid", "invalid"],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["version", "source", "official_example_base", "official_example_check_digits", "updated_at"],
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "schema": { "type": "string" },
        "source": { "type": "string" },
        "official_example_base": { "type": "string", "pattern": "^[A-Z0-9]{12}$" },
        "official_example_check_digits": { "type": "string", "pattern": "^[0-9]{2}$" },
        "updated_at": { "type": "string", "format": "date" }
      },
      "additionalProperties": false
    },
    "valid": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "value", "normalized", "formatted"],
        "properties": {
          "id": { "type": "string" },
          "value": { "type": "string" },
          "normalized": { "type": "string", "pattern": "^[A-Z0-9]{12}[0-9]{2}$" },
          "formatted": { "type": "string", "pattern": "^[A-Z0-9]{2}\\.[A-Z0-9]{3}\\.[A-Z0-9]{3}/[A-Z0-9]{4}-[0-9]{2}$" }
        },
        "additionalProperties": false
      }
    },
    "invalid": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "value", "reason"],
        "properties": {
          "id": { "type": "string" },
          "value": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  }
}
